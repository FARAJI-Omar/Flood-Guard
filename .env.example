# Database
DB_URL=jdbc:postgresql://localhost:5432/flood_guard
DB_USERNAME=username
DB_PASSWORD=password

# JWT 
JWT_SECRET=replace_with_a_long_random_secret_min_32_bytes
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# Optional admin bootstrap (dev only)
APP_SEED_ADMIN_ENABLED=false
APP_SEED_ADMIN_USERNAME=admin_username
APP_SEED_ADMIN_EMAIL=admin_email
APP_SEED_ADMIN_PASSWORD=password

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:*
